APP_ENV=development

POSTGRES_USER=app_usr   
POSTGRES_PASSWORD=app_usr_pass
POSTGRES_DB=app_db
POSTGRES_PORT=5432

DATABASE_URL=postgresql://app_usr:app_usr_pass@postgres:5432/app_db

API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000
MODEL_SERVER_URL=http://model-server:8000

EMBEDDING_PROVIDER=deterministic
EMBEDDING_MODEL=deterministic-hash-v1
EMBEDDING_DIMENSIONS=384
