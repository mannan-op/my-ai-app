APP_ENV=development

POSTGRES_USER=app_usr   
POSTGRES_PASSWORD=app_usr_pass
POSTGRES_DB=app_db
POSTGRES_PORT=5432

DATABASE_URL=postgresql://app_usr:app_usr_pass@postgres:5432/app_db

API_PORT=4000
NEXT_PUBLIC_API_URL=http://localhost:4000
MODEL_SERVER_URL=http://model-server:8000

MODEL_DEVICE=auto
MODEL_CACHE_DIR=
MODEL_BATCH_SIZE=1
MODEL_MAX_SEQUENCE_LENGTH=512
MODEL_PRELOAD=false
TAPAS_MODEL_NAME=google/tapas-base-finetuned-wtq
NLI_MODEL_NAME=cross-encoder/nli-deberta-v3-small
LAYOUT_DOCUMENT_QA_MODEL_NAME=impira/layoutlm-document-qa
VISION_QA_MODEL_NAME=dandelin/vilt-b32-finetuned-vqa
SECTION_CLASSIFIER_MODEL_NAME=facebook/bart-large-mnli

EMBEDDING_PROVIDER=deterministic
EMBEDDING_MODEL=deterministic-hash-v1
EMBEDDING_DIMENSIONS=384
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_EMBEDDING_DIMENSIONS=384

LANGFUSE_ENABLED=false
LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
